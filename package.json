{
  "name": "hackweek-workflow-decision-log",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:create": "wrangler d1 create decision-log",
    "db:migrate": "wrangler d1 migrations apply decision-log --remote",
    "db:migrate:local": "wrangler d1 migrations apply decision-log --local",
    "dev:worker": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.1",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wrangler": "^4.101.0"
  }
}
